{
  "name": "@alfadb/pi-astack",
  "version": "0.1.0",
  "description": "alfadb's personal pi workflow + memory infrastructure: extensions, skills, prompts built specifically for pi (similar to how gstack is built for claude-code). Memory architecture: pure markdown+git (project-level .pensieve/, world-level ~/.abrain/); main session read-only via memory_search/get/list/neighbors; sediment sidecar is the sole writer via internal create/update/merge/archive/supersede/delete/skip substrate. gbrain entirely removed (2026-05-07, memory-architecture.md). Vendors garrytan/gstack as port reference; consolidates alfadb-native dispatch / model-curator / model-fallback.",
  "keywords": [
    "pi-package",
    "alfadb",
    "workflow",
    "review",
    "qa",
    "memory",
    "markdown",
    "sediment",
    "dispatch",
    "model-curator"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:alfadb/pi-astack.git"
  },
  "scripts": {
    "smoke:memory": "node scripts/smoke-memory-sediment.mjs",
    "smoke:dispatch": "node scripts/smoke-dispatch-input-compat.mjs",
    "smoke:fallback-timing": "node scripts/smoke-model-fallback-mutation-timing.mjs",
    "smoke:paths": "node scripts/smoke-pi-astack-paths.mjs",
    "smoke:vault-subpi-isolation": "node scripts/smoke-vault-subpi-isolation.mjs",
    "smoke:abrain": "node scripts/smoke-abrain-backend-detect.mjs",
    "smoke:abrain-bootstrap": "node scripts/smoke-abrain-bootstrap.mjs",
    "smoke:abrain-vault-writer": "node scripts/smoke-abrain-vault-writer.mjs",
    "smoke:abrain-vault-reader": "node scripts/smoke-abrain-vault-reader.mjs",
    "smoke:abrain-vault-bash": "node scripts/smoke-abrain-vault-bash.mjs",
    "smoke:abrain-active-project": "node scripts/smoke-abrain-active-project.mjs",
    "smoke:abrain-secret-scope": "node scripts/smoke-abrain-secret-scope.mjs",
    "smoke:abrain-i18n": "node scripts/smoke-abrain-i18n.mjs"
  },
  "pi": {
    "extensions": ["./extensions"],
    "skills": ["./skills"],
    "prompts": ["./prompts", "./extensions/dispatch/prompts"]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  }
}
